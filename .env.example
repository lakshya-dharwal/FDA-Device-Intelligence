# ── Required ──────────────────────────────────────────────────────────────────
# Your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Claude tuning (defaults shown) ──────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_MAX_TOKENS=4096
# Hard cap on agentic tool-use rounds per query (cost guard rail)
MAX_AGENT_ITERATIONS=10
# Pricing in USD per million tokens (used for cost telemetry)
INPUT_COST_PER_MTOK=3.00
OUTPUT_COST_PER_MTOK=15.00

# ── Optional: OpenFDA ─────────────────────────────────────────────────────────
OPENFDA_BASE=https://api.fda.gov
OPENFDA_TIMEOUT=10

# ── Optional: Telemetry & wiring ──────────────────────────────────────────────
# Telemetry backend: "sqlite" (local/dev) or "firestore" (Cloud Run / V2)
TELEMETRY_BACKEND=sqlite
# Path to the local SQLite telemetry store (sqlite backend only)
TELEMETRY_DB_PATH=telemetry.db
# Firestore collection name (firestore backend only)
FIRESTORE_COLLECTION=queries
# Backend URL the Streamlit frontend talks to (set to your Cloud Run URL in prod)
FDA_API_URL=http://localhost:8000

# ── Optional: Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
